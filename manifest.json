{
  "manifest_version": 2,
  "name": "Smart Reading Tracker",
  "version": "1.0.0",
  "description": "Smart Reading Tracker enhances your browsing experience by visually highlighting headings and text content, helping you focus while reading. Non-intrusive visual enhancements that do not modify page structure.",
  "author": "Smart Reading Tracker",
  "homepage_url": "https://github.com/Akshata153/SmartReader-Firefox-extension",

  "browser_specific_settings": {
    "gecko": {
      "id": "smartreader@akshata153.github.io",
      "strict_min_version": "109.0",
      "update_url": "https://akshata153.github.io/SmartReader-Firefox-extension/updates.json"
    }
  },

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Smart Reading Tracker",
    "default_popup": "popup.html"
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}